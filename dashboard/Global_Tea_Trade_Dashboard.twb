              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;    WHEN &quot;Tea Yield&quot; THEN SUM([Yield_Kg_Ha])&#10;    WHEN &quot;Temperature&quot; THEN AVG([Temperature])&#10;    WHEN &quot;Production&quot; THEN SUM([Production_Ton])&#10;END' />
