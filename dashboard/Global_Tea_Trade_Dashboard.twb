    <worksheet name='Ranking Tea Producers: Sort by Yield, Temp or Production'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Medium'>&lt;Sheet Name&gt;</run>
            <run>Æ&#10;</run>
            <run bold='true' fontsize='12' italic='true'>Use dropdown to sort into</run>
            <run bold='true' fontsize='12'> [</run>
            <run bold='true' fontcolor='#e76865' fontsize='12'>Top 3</run>
            <run bold='true' fontsize='12'> |</run>
            <run fontsize='12'>Æ </run>
            <run bold='true' fontcolor='#ffd090' fontsize='12'>Bottom 3</run>
            <run bold='true' fontsize='12'>]</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='df_main_tea_gdp_climate' name='federated.1mxjagq0kcqjqg1eok9ci100pu3m' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Sort By' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Temperature&quot;'>
              <calculation class='tableau' formula='&quot;Temperature&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1mxjagq0kcqjqg1eok9ci100pu3m'>
            <column caption='Dynamic Sort' datatype='real' name='[Calculation_0967272165076994]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;    WHEN &quot;Tea Yield&quot; THEN SUM([Yield_Kg_Ha])&#10;    WHEN &quot;Temperature&quot; THEN AVG([Temperature])&#10;    WHEN &quot;Production&quot; THEN SUM([Production_Ton])&#10;END' />
